block variables 
doctype html 
html 
  head
    meta(charset="utf-8")
    title A1 Portfolio Site
    block scripts 
      link(rel="stylesheet", type="text/css", href="/styles.css")
      link(rel="stylesheet", 
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=cancel,check,delete,edit_square")
  body
    header  
      h1.site-name: a(href="/") Portfolio Site
      nav
        if (user)
          ul 
            li: a(href="/admin").nav-button Admin 
            li: a(href="/logout").nav-button Logout 
        else 
          a(href="/login").nav-button Login
    main 
      block main-content 
    footer 
      p &copy; Copyright HTTP5211, 2026.