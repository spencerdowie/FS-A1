extends layout

block main-content 
  .login-box 
    h1 Login
    if err
      p #{err}
    form(method="post", action="/login")
      div#login-field 
        label(for="u") Username: 
        input(type="text", id="u", name="u")
      div#login-field
        label(for="pw") Password: 
        input(type="password", id="pw", name="pw")
      button.login-submit(type="submit") Log in
    p. 
      Don't have an account? #[a(href="/register") Register now]